# =============================================================================
# Aureo Project Management — .gitignore
# =============================================================================
# Policy: commit only sources, the schema-of-record migration, and config
# required for reproducible installs. Everything generated, environment-
# specific, or transient stays out.
# =============================================================================


# -----------------------------------------------------------------------------
# Secrets, env, credentials  (NEVER commit)
# -----------------------------------------------------------------------------
.env
.env.*
!.env.example
*.key
*.pem
*.p12
*.pfx
*.ppk
*.crt
auth.json
secrets/
.secrets/


# -----------------------------------------------------------------------------
# PHP / Composer
# -----------------------------------------------------------------------------
/vendor/
composer.lock
composer.phar
.php-cs-fixer.cache
.phpunit.cache/
.phpunit.result.cache
.phpstan.cache/
.psalm-cache/
/coverage/
/coverage.xml
/clover.xml
/report.xml


# -----------------------------------------------------------------------------
# Database — Phinx migrations & seeds
# -----------------------------------------------------------------------------
# The canonical migration in db/migrations/ IS committed; `composer setup`
# depends on it. Ignore only generated scratch files, editor backups, and
# developer-local experiments that must not reach main.
db/migrations/*.bak
db/migrations/*.tmp
db/migrations/*.orig
db/migrations/*.swp
db/migrations/*.local.php
db/migrations/_*.php
db/migrations/scratch/
db/seeds/*.bak
db/seeds/*.tmp
db/seeds/*.local.php
db/seeds/scratch/

# Raw SQL dumps and one-off scripts produced during development
*.sql.bak
*.dump
*.dump.sql
dump.sql
dump_*.sql
backup_*.sql
*.mwb.bak


# -----------------------------------------------------------------------------
# Logs (the app writes to /log; webserver logs may also land in tree)
# -----------------------------------------------------------------------------
*.log
log/
logs/
storage/logs/
npm-debug.log*
yarn-error.log*


# -----------------------------------------------------------------------------
# Cache / runtime / temp
# -----------------------------------------------------------------------------
cache/
tmp/
temp/
var/cache/
var/tmp/
var/sessions/
storage/framework/cache/
storage/framework/sessions/
storage/framework/views/
sessions/
.session


# -----------------------------------------------------------------------------
# Node / Tailwind / build artifacts
# -----------------------------------------------------------------------------
/node_modules/
package-lock.json
yarn.lock
pnpm-lock.yaml
.npm/
.yarn/
.pnp.*
.tailwindcss/
tailwind.config.cache
postcss.cache/

# Compiled CSS/JS — keep sources, not output
/public/assets/css/styles.css
/public/css/output.css
/public/js/*.bundle.js
/public/build/
/public/dist/


# -----------------------------------------------------------------------------
# Local tooling installed via composer scripts (phpMyAdmin etc.)
# -----------------------------------------------------------------------------
/tools/


# -----------------------------------------------------------------------------
# User uploads / runtime media (per-environment, never committed)
# -----------------------------------------------------------------------------
/uploads/
/public/uploads/
/storage/app/public/


# -----------------------------------------------------------------------------
# IDE / editor
# -----------------------------------------------------------------------------
.idea/
*.iml
.vscode/
*.code-workspace
.history/
*.sublime-project
*.sublime-workspace
.settings/
.project
.classpath
.buildpath
nbproject/
*.swp
*.swo
*~


# -----------------------------------------------------------------------------
# OS metadata
# -----------------------------------------------------------------------------
.DS_Store
.AppleDouble
.LSOverride
Icon?
._*
Thumbs.db
ehthumbs.db
ehthumbs_vista.db
Desktop.ini
$RECYCLE.BIN/


# -----------------------------------------------------------------------------
# Generic temp/backup file patterns
# -----------------------------------------------------------------------------
*.bak
*.backup
*.tmp
*.temp
*.orig
*.rej
*.old


# -----------------------------------------------------------------------------
# Claude / agent local state
# -----------------------------------------------------------------------------
# .claude/CLAUDE.md IS committed (agentic project guidance). Per-developer
# memory, settings, and orchestrator output are not.
/.claude/memory/
/.claude/settings.local.json
/.claude/cache/
/.claude/artifacts/
/.claude/orchestrator/
